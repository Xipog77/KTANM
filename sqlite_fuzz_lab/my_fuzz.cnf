[mysqld]
port = 3308
socket = /tmp/mysql_fuzz.sock
pid-file = /tmp/mysql_fuzz.pid
datadir = /home/dokhanh/mysql_data
secure_file_priv = ""
bind-address = 127.0.0.1
mysqlx = OFF

# Extreme Performance Optimizations for Fuzzing
performance_schema = OFF
skip-log-bin
innodb_flush_log_at_trx_commit = 0
innodb_doublewrite = 0
innodb_flush_method = O_DIRECT
innodb_buffer_pool_size = 256M
innodb_log_buffer_size = 64M
tmp_table_size = 64M
max_heap_table_size = 64M
ssl = 0
log_error_verbosity = 1

# Thread and Background Activity Minimization to Improve AFL Stability and Speed
innodb_thread_concurrency = 1
innodb_write_io_threads = 2
innodb_read_io_threads = 2
innodb_purge_threads = 1
innodb_page_cleaners = 1
thread_cache_size = 0
